<!-- Forge-Change -->
<PanelContainer xmlns="https://spacestation14.io"
                HorizontalExpand="True"
                Margin="0 0 0 5">

    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True"
                  SeparationOverride="4">

        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True"
                      VerticalAlignment="Center">

            <Label Name="TimerLabel"
                   HorizontalExpand="True"
                   Margin="0 0 10 0" />

            <Label Name="TimeLabel"
                   MinWidth="80"
                   HorizontalAlignment="Right" />

            <Button Name="RemoveButton"
                    Text="{Loc 'sec-apartment-ui-timers-remove'}"
                    ToolTip="{Loc 'sec-apartment-ui-timers-remove-tooltip'}"
                    MinWidth="40"
                    Margin="5 0 0 0" />

        </BoxContainer>

        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True"
                      VerticalAlignment="Center">

            <Label Name="TotalTimeHeaderLabel"
                   Text="{Loc 'sec-apartment-ui-timers-total-time'}"
                   StyleClasses="ConsoleSubHeading"
                   Margin="0 0 5 0" />

            <Label Name="TotalTimeLabel"
                   HorizontalExpand="True"
                   StyleClasses="ConsoleText" />

        </BoxContainer>

        <PanelContainer Name="Divider" StyleClasses="LowDivider" HorizontalExpand="True" Margin="0 2 0 2" SetHeight="1"/>

    </BoxContainer>

</PanelContainer>
